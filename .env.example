# =============================================================================
# Переменные окружения для клиента (Vite)
# Скопируйте в .env и подставьте значения из Supabase Dashboard → Settings → API
# =============================================================================

# Корень проекта Supabase (без /rest/v1 в конце)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Публичный anon / publishable key (безопасен для браузера при включённом RLS)
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Базовый URL фронтенда для ссылок в письмах (подтверждение email, сброс пароля)
# Dev: http://localhost:5173  |  Prod: https://your-domain.com
VITE_SITE_URL=http://localhost:5173

# ВАЖНО: не добавляйте service_role key, TELEGRAM_BOT_TOKEN и другие приватные ключи в клиентский .env
# Telegram: TELEGRAM_BOT_TOKEN, TELEGRAM_BOT_USERNAME, CRON_SECRET — только в Supabase Edge Functions Secrets
VITE_TELEGRAM_BOT_USERNAME=
